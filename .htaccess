DirectoryIndex index.html index.php

# Quanto Custa Solar — configuração mínima compatível com hospedagem compartilhada.
# Evita diretivas que podem gerar 500/503 em alguns ambientes Apache/KingHost.

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Bloqueia acesso público a pastas internas sensíveis.
  RewriteRule ^(config|includes|database|tools)(/|$) - [F,L]
</IfModule>
